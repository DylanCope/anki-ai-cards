# Claude tool-use agent
ANTHROPIC_API_KEY=

# ElevenLabs TTS
ELEVENLABS_API_KEY=

# Google OAuth (Sign in with Google + Docs API access)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# The single Google account allowed to use the app
ALLOWED_EMAIL=

# The public URL users actually access the app at (the frontend's origin) —
# used to build the OAuth redirect_uri. Must NOT be derived from incoming
# request headers: every request arrives via the frontend's proxy, so the
# backend would otherwise see (and leak to Google) its own private address
# instead. Local dev: http://localhost:3000. Production: the frontend's
# public https://...fly.dev URL (or custom domain).
PUBLIC_APP_URL=http://localhost:3000

# Random secret used to sign session cookies (e.g. `openssl rand -hex 32`)
SESSION_SECRET_KEY=

# Optional bearer-token bypass for require_auth (e.g. `openssl rand -hex 32`),
# used by scripts/smoke_test_chat.sh and the Ralph loop to call the API
# without a browser OAuth flow. Leave unset to disable the bypass entirely.
DEV_API_KEY=

# Base URL of the headless Anki + AnkiConnect instance. Local dev: your own
# desktop Anki + AnkiConnect addon. Production: the headless Anki app's
# Flycast address on port 8766, the socat relay — NOT .internal, and NOT
# AnkiConnect's own port 8765 directly; see
# deploy/anki-headless/fly.toml's header comment for why.
ANKICONNECT_URL=http://localhost:8765

# SQLite database file path
DATABASE_PATH=./data/anki-ai-cards.db

# Backend base URL, used by frontend/next.config.ts to proxy /api and /auth
# requests server-side so the session cookie stays same-origin from the browser
BACKEND_URL=http://localhost:8000
